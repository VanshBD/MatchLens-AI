# MatchLens AI – Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Socket.IO server URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# App info
NEXT_PUBLIC_APP_NAME=MatchLens AI
NEXT_PUBLIC_APP_ENV=development

# Map – OpenStreetMap via React Leaflet (NO API KEY REQUIRED)
# Uses free OpenStreetMap tiles — https://www.openstreetmap.org
# No billing, no limits for hackathon use
NEXT_PUBLIC_DEFAULT_STADIUM=metlife
